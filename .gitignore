# Secrets and local operator config must NEVER be committed. payfetch reads wallet
# keys from the environment or a chmod-600 key file, and writes its ledger, state,
# and config.json under the data dir (default ~/.payfetch). None of that belongs in
# git. Keep this list ahead of any `git add`.

# Wallet keys / credentials
.env
.env.*
*.env
*.key
*.pem

# Local operator state and config (default data dir + any project-local config)
.payfetch/
payfetch.config.json

# Build output (never committed; regenerated by `npm run build` / `build:mcpb`)
node_modules/
dist/
dist-mcpb/

# Tooling
coverage/
*.tgz
.DS_Store
